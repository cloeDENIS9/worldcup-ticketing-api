{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      ":@domain/*": [
        "domain/*"
      ],
      "@infrastructure/*": [
        "src/infrastructure/*"
      ],
      "@application/*": [
        "src/application/*"
      ],
    },
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  }
}